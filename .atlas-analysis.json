    "App.Static() - Serve static files",
    "Ctx.JSON() - Send JSON response",
    "Ctx.SendString() - Send string response",
    "Ctx.Params() - Get route parameters",
    "Ctx.Query() - Get query parameters",
    "Ctx.Body() - Get request body",
    "Ctx.Bind() - Bind request to struct",
    "Ctx.Next() - Call next middleware",
    "Ctx.Redirect() - Redirect request",
    "Ctx.Cookie() - Set cookie",
    "Ctx.Render() - Render template",
